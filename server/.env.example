# ---- Database (Supabase) ----
# Runtime connection via the transaction pooler (port 6543, ?pgbouncer=true)
DATABASE_URL=
# Direct connection — used ONLY by Prisma migrations
DIRECT_URL=

# ---- Auth (better-auth) ----
BETTER_AUTH_SECRET=            # random secret for signing sessions
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:5173   # comma-separated allowed origins (also drives CORS + CSRF check)

# ---- AI (OpenRouter, OpenAI-compatible) ----
AI_API_KEY=
# Optional model overrides (comma-separated list / single model)
# GEN_MODELS=openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,qwen/qwen3-coder:free
# GEN_MODEL=
# EDIT_MODEL=qwen/qwen3-coder:free

# ---- Payments (Stripe) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Email (optional) ----
# When set, verification/reset emails send via Resend and email verification is
# ENFORCED. When unset, links are logged to the console and verification is off.
RESEND_API_KEY=
EMAIL_FROM=GenSite <onboarding@resend.dev>

# ---- Storage (optional) ----
# inline (default, Postgres) or s3 — see SCALING.md
STORAGE_DRIVER=inline

# ---- Observability (all optional; no-op unless key set AND the SDK is installed) ----
# Error monitoring — `npm i @sentry/node`
SENTRY_DSN=
# LLM tracing (cost/latency/tokens) — `npm i langfuse`
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ---- Misc ----
NODE_ENV=development
# PORT is injected by most hosts (Render); defaults to 3000 locally.
